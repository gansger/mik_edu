# Скопируйте в .env и заполните (в корне проекта, рядом с docker-compose.yml)
# cp .env.example .env

JWT_SECRET=change-me-in-production
# Ключ Groq для генерации вопросов теста (console.groq.com). Оставьте пустым, если не нужна генерация ИИ.
QWEN_API_KEY=
# Опционально (по умолчанию уже верный URL): QWEN_API_URL=https://api.groq.com/openai/v1/chat/completions — только groq.com (буква q), не grok.com
