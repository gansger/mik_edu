# Скопируйте в .env и заполните (в корне проекта, рядом с docker-compose.yml)
# cp .env.example .env

JWT_SECRET=change-me-in-production
# Ключ Groq для генерации вопросов теста (console.groq.com). Оставьте пустым, если не нужна генерация ИИ.
QWEN_API_KEY=

# Опционально: HTTP(S)-прокси для исходящих запросов к api.groq.com (если без docker-compose.vpn.yml)
# HTTPS_PROXY=http://user:pass@proxy.example:8080
